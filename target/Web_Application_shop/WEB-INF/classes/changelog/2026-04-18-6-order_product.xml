<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="6" author="Oleg">
        <createTable tableName="userOrder_product">
            <column name="userOrder_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="productCount" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="7" author="Oleg">
        <addPrimaryKey tableName="userOrder_product"
                       columnNames="userOrder_id, product_id"
                       constraintName="pk_userOrder_product"/>
    </changeSet>
</databaseChangeLog>